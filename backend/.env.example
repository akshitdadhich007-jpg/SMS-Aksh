# ── Server ──
NODE_ENV=development
PORT=3001

# ── Supabase (REQUIRED) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Authentication ──
JWT_SECRET=generate-a-random-64-char-secret
JWT_EXPIRES_IN=24h

# ── CORS ──
# Comma-separated origins. Leave empty for dev defaults (localhost:5173, 5174, 3000)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ── Logging ──
# LOG_LEVEL=info
# LOG_DIR=logs

# ── Rate Limiting (optional, defaults shown) ──
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200
# AUTH_RATE_LIMIT_WINDOW_MS=3600000
# AUTH_RATE_LIMIT_MAX=10

# ── Storage Buckets (optional, defaults shown) ──
# STORAGE_BUCKET_SURVEILLANCE=surveillance-images
# STORAGE_BUCKET_LOST_FOUND=lost-found-images
# STORAGE_BUCKET_PROOFS=proof-uploads

# ── Matching Engine (optional, defaults shown) ──
# MATCH_SCORE_CATEGORY=40
# MATCH_SCORE_COLOR=30
# MATCH_SCORE_DATE_PENALTY=5

# ── Approval Code (optional, defaults shown) ──
# APPROVAL_CODE_LENGTH=6
# APPROVAL_CODE_CHARS=ABCDEFGHJKLMNPQRSTUVWXYZ23456789

# ── Demo Mode ──
DEMO_MODE=true
